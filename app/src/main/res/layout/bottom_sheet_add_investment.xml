<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_surface"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Yeni Yatırım Ekle"
        android:textColor="?attr/colorOnSurface"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"
        android:text="Varlık ve alış bilgilerinizi kaydedin"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp" />

    <!-- Varlık türü -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutAssetType"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Varlık Türü"
        app:boxBackgroundColor="?attr/colorSurface"
        app:boxStrokeColor="?attr/colorPrimary"
        app:hintTextColor="?attr/colorOnSurfaceVariant"
        app:placeholderText="Örnek: USD, EUR veya Gram Altın">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/etAssetType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            tools:ignore="SpeakableTextPresentCheck" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Miktar -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutInvestmentAmount"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Miktar"
        app:boxBackgroundColor="?attr/colorSurface"
        app:boxStrokeColor="?attr/colorPrimary"
        app:hintTextColor="?attr/colorOnSurfaceVariant"
        app:placeholderText="Örnek: 1, 2,5 veya 10">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etInvestmentAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            tools:ignore="SpeakableTextPresentCheck" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Kur seçim başlığı -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:text="Alış kuru"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp" />

    <!-- Kur seçim seçenekleri -->
    <RadioGroup
        android:id="@+id/rgRateType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbCurrentRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Güncel Kur"
            android:textColor="?attr/colorOnSurface"
            app:buttonTint="?attr/colorPrimary" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/rbManualRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Geçmiş / Manuel"
            android:textColor="?attr/colorOnSurface"
            app:buttonTint="?attr/colorPrimary" />

    </RadioGroup>

    <!-- Manuel alış kuru -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutManualRate"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Alış Kuru"
        android:visibility="gone"
        app:boxBackgroundColor="?attr/colorSurface"
        app:boxStrokeColor="?attr/colorPrimary"
        app:hintTextColor="?attr/colorOnSurfaceVariant"
        app:placeholderText="Örnek: 34,50">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etManualRate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            tools:ignore="SpeakableTextPresentCheck" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveInvestment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="54dp"
        android:text="Yatırımı kaydet"
        android:textAllCaps="false"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="?attr/colorPrimary"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_save"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="?attr/colorOnPrimary" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
